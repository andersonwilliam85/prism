ARG FEDORA_VERSION=39
FROM fedora:${FEDORA_VERSION}

RUN dnf install -y python3 python3-pip git openssh-clients curl \
    && dnf clean all

RUN useradd -m -s /bin/bash testuser
COPY --chown=testuser:testuser . /home/testuser/prism/
USER testuser
WORKDIR /home/testuser/prism
RUN python3 -m pip install --user --no-cache-dir flask pyyaml requests pytest
